# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail SMTP (Email Transactional)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Resend (Email API)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Cakto Payment Gateway
CAKTO_CLIENT_ID=your_cakto_client_id
CAKTO_CLIENT_SECRET=your_cakto_client_secret
CAKTO_OFFER_MONTHLY_ID=your_monthly_offer_id
CAKTO_OFFER_ANNUAL_ID=your_annual_offer_id

# Admin
ADMIN_EMAIL=seu-email@dominio.com.br


